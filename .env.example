# Boltcall environment variables
# Copy to .env and fill in values. Never commit .env.

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── PayPal ────────────────────────────────────────────────────────────────
# Switch this to control which credentials the webhook + checkout use.
PAYPAL_MODE=sandbox

# Live credentials (used when PAYPAL_MODE != sandbox)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Sandbox credentials (used when PAYPAL_MODE=sandbox)
# Get these from https://developer.paypal.com → Apps & Credentials → Sandbox
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_CLIENT_SECRET=
PAYPAL_SANDBOX_WEBHOOK_ID=

# PayPal Subscription Plan IDs (P-XXX format) — created via scripts/paypal/create-plan.mjs
# Sandbox plan IDs
PAYPAL_PLAN_STARTER_MONTHLY_SANDBOX=
PAYPAL_PLAN_STARTER_YEARLY_SANDBOX=
PAYPAL_PLAN_PRO_MONTHLY_SANDBOX=
PAYPAL_PLAN_PRO_YEARLY_SANDBOX=
PAYPAL_PLAN_ULTIMATE_MONTHLY_SANDBOX=
PAYPAL_PLAN_ULTIMATE_YEARLY_SANDBOX=

# Live plan IDs
PAYPAL_PLAN_STARTER_MONTHLY=
PAYPAL_PLAN_STARTER_YEARLY=
PAYPAL_PLAN_PRO_MONTHLY=
PAYPAL_PLAN_PRO_YEARLY=
PAYPAL_PLAN_ULTIMATE_MONTHLY=
PAYPAL_PLAN_ULTIMATE_YEARLY=

# Boltcall product IDs (one per environment, created once via scripts/paypal/create-product.mjs)
PAYPAL_PRODUCT_ID_SANDBOX=
PAYPAL_PRODUCT_ID=

# ── Stripe (parallel checkout, optional) ──────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ULTIMATE_MONTHLY=
STRIPE_PRICE_ULTIMATE_YEARLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=

# ── Notifications ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
